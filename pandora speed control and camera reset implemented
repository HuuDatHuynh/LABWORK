#include <IRremote.h>
#include <Servo.h>

// ================== IR ===================
#define IR_RECEIVE_PIN 9

// ---- Camera joystick IR codes ----
#define UP_CODE     0xFF2000
#define DOWN_CODE   0xFFC000
#define LEFT_CODE   0xFF8000
#define RIGHT_CODE  0xFF4000
// ---- Car movement codes ----------
#define TURN_RIGHT_CODE     0xEA15FF00
#define BACKWARD_CODE    0xBB44FF00
#define TURN_LEFT_CODE   0xB946FF00
#define FORWARD_CODE  0xBC43FF00
#define STOP_CODE        0xBF40FF00

// ---- New buttons ------------------
#define RESET_CAM_CODE   0xFF38C7
#define MODE_CAR_CODE    0xFF10EF   // yellow
#define SPEED_DOWN_CODE  0xFF7A85   // black
#define SPEED_UP_CODE    0xFF18E7   // white
#define MODE_WALK_CODE   0xFF30CF   // blue

// ================== SERVOS ==================
#define SERVO_X_PIN 10
#define SERVO_Y_PIN 11

Servo servoX;
Servo servoY;
int servoXPos = 90;
int servoYPos = 90;

const int NUDGE_STEP = 5;    // Smaller step for smooth continuous
const int SMOOTH_DELAY = 10;

// ================== MOTOR PINS ==============
#define AIN1 7
#define AIN2 8
#define PWMA 5
#define PWMB 6
#define STANDBY 3

// ================== SPEED CONTROL ===========
int speedValue = 80;
const int speedStep = 10;
String lastDirection = "STOP";
bool isStopped = true;

// ================== MODES ===================
int currentMode = 0; // 0 = CAR, 1 = WALKER

// ================== Servo movement delta =====
int servoXDelta = 0;
int servoYDelta = 0;

// ================== FUNCTIONS ===============

// --- Continuous servo movement ---
void moveServoContinuous(Servo &s, int &pos, int delta) {
  pos = constrain(pos + delta, 0, 180);
  s.write(pos);
}

// --- Motor functions ---
void Forward(byte speed) {
  digitalWrite(AIN1, HIGH);
  digitalWrite(AIN2, HIGH);
  analogWrite(PWMA, speed);
  analogWrite(PWMB, speed);
  digitalWrite(STANDBY, HIGH);
  Serial.println("Moving Forward");
}

void Backward(byte speed) {
  digitalWrite(AIN1, LOW);
  digitalWrite(AIN2, LOW);
  analogWrite(PWMA, speed);
  analogWrite(PWMB, speed);
  digitalWrite(STANDBY, HIGH);
  Serial.println("Moving Backward");
}

void Left(byte speed) {
  digitalWrite(AIN1, HIGH);
  digitalWrite(AIN2, LOW);
  analogWrite(PWMA, speed);
  analogWrite(PWMB, speed);
  digitalWrite(STANDBY, HIGH);
  Serial.println("Turning Left");
}

void Right(byte speed) {
  digitalWrite(AIN1, LOW);
  digitalWrite(AIN2, HIGH);
  analogWrite(PWMA, speed);
  analogWrite(PWMB, speed);
  digitalWrite(STANDBY, HIGH);
  Serial.println("Turning Right");
}

void StopMotors() {
  analogWrite(PWMA, 0);
  analogWrite(PWMB, 0);
  digitalWrite(STANDBY, HIGH);
  Serial.println("Motors Stopped");
}

// --- Apply last direction after speed change ---
void applyLastDirection() {
  if (isStopped) return;
  if (lastDirection == "FORWARD") Forward(speedValue);
  else if (lastDirection == "BACKWARD") Backward(speedValue);
  else if (lastDirection == "LEFT") Left(speedValue);
  else if (lastDirection == "RIGHT") Right(speedValue);
}

// ================== SETUP ===================
void setup() {
  Serial.begin(9600);

  servoX.attach(SERVO_X_PIN);
  servoY.attach(SERVO_Y_PIN);
  servoX.write(servoXPos);
  servoY.write(servoYPos);

  pinMode(AIN1, OUTPUT);
  pinMode(AIN2, OUTPUT);
  pinMode(PWMA, OUTPUT);
  pinMode(PWMB, OUTPUT);
  pinMode(STANDBY, OUTPUT);
  digitalWrite(STANDBY, HIGH);

  IrReceiver.begin(IR_RECEIVE_PIN, ENABLE_LED_FEEDBACK);

  Serial.println("Camera + Car System Ready");
}

// ================== LOOP ====================
void loop() {

  servoXDelta = 0;
  servoYDelta = 0;

  if (IrReceiver.decode()) {
    uint32_t code = IrReceiver.decodedIRData.decodedRawData;

    // Ignore null and repeat codes
    if (code != 0x0) {

      // ===== CAMERA RESET =====
     // ===== CAMERA RESET =====
if (code == RESET_CAM_CODE) {
    // Reset servo positions to neutral
    servoXPos = 90;
    servoYPos = 90;
    servoX.write(servoXPos);
    servoY.write(servoYPos);

    // Clear any movement deltas so camera stops immediately
    servoXDelta = 0;
    servoYDelta = 0;

    Serial.println("Camera Reset to Neutral Position");
}

      // ===== CAMERA CONTROL =====
      else if (code == LEFT_CODE)  servoXDelta = -NUDGE_STEP;
      else if (code == RIGHT_CODE) servoXDelta = NUDGE_STEP;
      else if (code == UP_CODE)    servoYDelta = -NUDGE_STEP;
      else if (code == DOWN_CODE)  servoYDelta = NUDGE_STEP;

      // ===== MODE SWITCH =====
      else if (code == MODE_CAR_CODE) {
        currentMode = 0;
        isStopped = false;
        Serial.println("CAR MODE");
      } else if (code == MODE_WALK_CODE) {
        currentMode = 1;
        StopMotors();
        Serial.println("WALKER MODE");
      }

      // ===== SPEED CONTROL =====
      else if (code == SPEED_UP_CODE) {
        speedValue += speedStep;
        if (speedValue > 255) speedValue = 255;
        Serial.print("Speed increased: ");
        Serial.println(speedValue);
        applyLastDirection();
      } else if (code == SPEED_DOWN_CODE) {
        speedValue -= speedStep;
        if (speedValue < 0) speedValue = 0;
        Serial.print("Speed decreased: ");
        Serial.println(speedValue);
        applyLastDirection();
      }

      // ===== CAR CONTROLS (only in CAR MODE) =====
      else if (currentMode == 0) {
        if (code == FORWARD_CODE) {
          Forward(speedValue);
          lastDirection = "FORWARD";
          isStopped = false;
        } else if (code == BACKWARD_CODE) {
          Backward(speedValue);
          lastDirection = "BACKWARD";
          isStopped = false;
        } else if (code == TURN_LEFT_CODE) {
          Left(speedValue);
          lastDirection = "LEFT";
          isStopped = false;
        } else if (code == TURN_RIGHT_CODE) {
          Right(speedValue);
          lastDirection = "RIGHT";
          isStopped = false;
        } else if (code == STOP_CODE) {
          StopMotors();
          lastDirection = "STOP";
          isStopped = true;
        }
      }
    }

    IrReceiver.resume();
  }

  // Apply continuous servo movement
  if (servoXDelta != 0) moveServoContinuous(servoX, servoXPos, servoXDelta);
  if (servoYDelta != 0) moveServoContinuous(servoY, servoYPos, servoYDelta);

  delay(SMOOTH_DELAY);
}
