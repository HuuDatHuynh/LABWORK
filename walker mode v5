// ============================================================
//  Quadruped Robot — One Leg At A Time (Low Power)
//  States:
//    REST      → curled up, servos DETACHED (inactive, low power)
//               only wakes on MODE_WALK_CODE
//    STAND     → standing still, servos attached and holding
//    WALK_FORWARD / WALK_BACKWARD / TURN_LEFT / TURN_RIGHT
//               → active walking, controllable via IR
//
//  MODE_WALK_CODE → robot stands up, becomes controllable
//  MODE_REST_CODE → robot curls up, detaches servos, ignores
//                   all commands except MODE_WALK_CODE
// ============================================================

#include <Servo.h>
#include <IRremote.hpp>

#define IR_RECEIVE_PIN 2

// ===== IR CODES =====
#define FORWARD_CODE    0xBC43FF00
#define BACKWARD_CODE   0xBB44FF00
#define TURN_LEFT_CODE  0xB946FF00
#define TURN_RIGHT_CODE 0xEA15FF00
#define STOP_CODE       0xBF40FF00
#define MODE_WALK_CODE  0xFF30CF
#define MODE_REST_CODE  0xFF10EF

// ===== IR DEBOUNCE =====
#define IR_DEBOUNCE_MS 150
unsigned long lastIRTime = 0;

// ===== SERVOS =====
Servo coxa[4];
Servo femur[4];
Servo tibia[4];

// Servo pin assignments stored so we can re-attach after sleep
const int coxaPin[4]  = {3,  6,  9,  12};
const int femurPin[4] = {4,  7,  10, A0};
const int tibiaPin[4] = {5,  8,  11, A1};

// ===== BASE POSITIONS =====
//
//  Physical layout (top-down view):
//
//          FRONT
//    [Leg 0]   [Leg 1]
//    Left       Right
//
//    [Leg 2]   [Leg 3]
//    Left       Right
//          BACK
//
int baseCoxa[4] = {90, 90, 90, 90};
int baseFemur   = 140;
int baseTibia   = 105;

// Coxa swing direction per leg:
//   Left  side legs (0, 2): forward = -30
//   Right side legs (1, 3): forward = +30
int coxaDir[4] = {-1, +1, -1, +1};

// Walking order — stable 3-legs-grounded sequence
// FL(0) → FR(1) → BR(3) → BL(2)
int walkOrder[4] = {0, 1, 3, 2};

// ===== TIMING =====
#define SERVO_SETTLE_MS  80
#define PHASE_DELAY_MS   180

// ===== STATE MACHINE =====
enum RobotState { REST, STAND, WALK_FORWARD, WALK_BACKWARD, TURN_LEFT, TURN_RIGHT };
RobotState currentState  = REST;   // start curled up and inactive
bool servosAttached = false;

// ===== SETUP =====
void setup() {
  Serial.begin(9600);
  IrReceiver.begin(IR_RECEIVE_PIN, ENABLE_LED_FEEDBACK);

  // Start in REST — attach servos briefly to curl up, then detach
  attachAllServos();
  restPose();
  detachAllServos();

  Serial.println("Robot sleeping. Send MODE_WALK_CODE to wake.");
}

// ===== LOOP =====
void loop() {

  if (IrReceiver.decode()) {
    unsigned long now = millis();

    if (now - lastIRTime > IR_DEBOUNCE_MS) {
      uint32_t cmd = IrReceiver.decodedIRData.decodedRawData;
      Serial.print("IR: 0x");
      Serial.println(cmd, HEX);

      // ── SLEEPING: only respond to MODE_WALK_CODE ──
      if (currentState == REST) {
        if (cmd == MODE_WALK_CODE) {
          wakeUp();           // attach servos + stand up
          currentState = STAND;
          Serial.println("Awake — standing by.");
        }
        // all other codes ignored while resting
      }

      // ── AWAKE: full command set ──
      else {
        if      (cmd == FORWARD_CODE)    currentState = WALK_FORWARD;
        else if (cmd == BACKWARD_CODE)   currentState = WALK_BACKWARD;
        else if (cmd == TURN_LEFT_CODE)  currentState = TURN_LEFT;
        else if (cmd == TURN_RIGHT_CODE) currentState = TURN_RIGHT;
        else if (cmd == STOP_CODE)       currentState = STAND;
        else if (cmd == MODE_WALK_CODE)  currentState = STAND;   // already awake, just stand
        else if (cmd == MODE_REST_CODE) {
          goToSleep();        // curl up + detach servos
          currentState = REST;
          Serial.println("Robot sleeping.");
        }
      }

      lastIRTime = now;
    }

    IrReceiver.resume();
  }

  // ── Execute current state ──
  switch (currentState) {
    case WALK_FORWARD:  walkForward();  break;
    case WALK_BACKWARD: walkBackward(); break;
    case TURN_LEFT:     turnLeft();     break;
    case TURN_RIGHT:    turnRight();    break;
    case STAND:
      // Just hold standing pose — do nothing, servos hold position
      break;
    case REST:
      // Inactive — servos detached, waiting for wake signal
      break;
  }
}

// ============================================================
//  SERVO ATTACH / DETACH
// ============================================================

void attachAllServos() {
  for (int i = 0; i < 4; i++) {
    coxa[i].attach(coxaPin[i]);
    femur[i].attach(femurPin[i]);
    tibia[i].attach(tibiaPin[i]);
  }
  servosAttached = true;
}

void detachAllServos() {
  for (int i = 0; i < 4; i++) {
    coxa[i].detach();
    femur[i].detach();
    tibia[i].detach();
  }
  servosAttached = false;
}

// ============================================================
//  WAKE UP  — attach servos and stand
// ============================================================
void wakeUp() {
  attachAllServos();
  delay(100);       // let servos power up before moving
  standPose();
}

// ============================================================
//  GO TO SLEEP  — curl up then detach servos
// ============================================================
void goToSleep() {
  restPose();
  delay(300);       // let servos finish moving before detaching
  detachAllServos();
}

// ============================================================
//  LOW-LEVEL HELPERS
//  Each servo moves individually with a settle delay after
// ============================================================

void moveCoxa(int leg, int angle) {
  coxa[leg].write(angle);
  delay(SERVO_SETTLE_MS);
}

void moveFemur(int leg, int angle) {
  femur[leg].write(angle);
  delay(SERVO_SETTLE_MS);
}

void moveTibia(int leg, int angle) {
  tibia[leg].write(angle);
  delay(SERVO_SETTLE_MS);
}

// ===== REST POSE (CURLED UP) =====
// One leg at a time with extra pause between legs to avoid power spikes
void restPose() {
  for (int i = 0; i < 4; i++) {
    moveTibia(i, 60);           // tuck lower leg first
    delay(PHASE_DELAY_MS);
    moveFemur(i, 90);           // fold middle joint
    delay(PHASE_DELAY_MS);
    moveCoxa(i,  90);           // center hip
    delay(PHASE_DELAY_MS * 2);  // extra pause before moving next leg
  }
}

// ===== STAND POSE (UPRIGHT, READY) =====
// One leg at a time with extra pause between legs to avoid power spikes
void standPose() {
  for (int i = 0; i < 4; i++) {
    moveCoxa(i,  baseCoxa[i]);  // center hip first
    delay(PHASE_DELAY_MS);
    moveFemur(i, baseFemur);    // extend middle joint
    delay(PHASE_DELAY_MS);
    moveTibia(i, baseTibia);    // extend lower leg to ground
    delay(PHASE_DELAY_MS * 2);  // extra pause before moving next leg
  }
}

// ============================================================
//  SINGLE LEG STEP
// ============================================================
void stepLeg(int leg, int coxaTarget) {
  // Phase 1: LIFT
  moveFemur(leg, baseFemur - 20);
  delay(PHASE_DELAY_MS);
  moveTibia(leg, baseTibia - 20);
  delay(PHASE_DELAY_MS);

  // Phase 2: SWING
  moveCoxa(leg, coxaTarget);
  delay(PHASE_DELAY_MS);

  // Phase 3: PLANT
  moveFemur(leg, baseFemur);
  delay(PHASE_DELAY_MS);
  moveTibia(leg, baseTibia);
  delay(PHASE_DELAY_MS);
}

// ============================================================
//  WALK FORWARD
//  Each leg: step forward, then reset coxa before next leg moves
// ============================================================
void walkForward() {
  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    int target = baseCoxa[leg] + (coxaDir[leg] * 30);
    stepLeg(leg, target);             // lift, swing, plant
    delay(PHASE_DELAY_MS);
    moveCoxa(leg, baseCoxa[leg]);     // reset this leg before next
    delay(PHASE_DELAY_MS);
  }
}

// ============================================================
//  WALK BACKWARD
//  Each leg: step backward, then reset coxa before next leg moves
// ============================================================
void walkBackward() {
  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    int target = baseCoxa[leg] - (coxaDir[leg] * 30);
    stepLeg(leg, target);
    delay(PHASE_DELAY_MS);
    moveCoxa(leg, baseCoxa[leg]);
    delay(PHASE_DELAY_MS);
  }
}

// ============================================================
//  TURN LEFT
//  Each leg: pivot step, then reset coxa before next leg moves
// ============================================================
void turnLeft() {
  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    int target = baseCoxa[leg] + 30;
    stepLeg(leg, target);
    delay(PHASE_DELAY_MS);
    moveCoxa(leg, baseCoxa[leg]);
    delay(PHASE_DELAY_MS);
  }
}

// ============================================================
//  TURN RIGHT
//  Each leg: pivot step, then reset coxa before next leg moves
// ============================================================
void turnRight() {
  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    int target = baseCoxa[leg] - 30;
    stepLeg(leg, target);
    delay(PHASE_DELAY_MS);
    moveCoxa(leg, baseCoxa[leg]);
    delay(PHASE_DELAY_MS);
  }
}
