// ============================================================
//  Quadruped Robot — One Leg At A Time (Low Power)
//  Power saving changes:
//    - Only 1 leg moves at a time, all others are still
//    - Extra settle delay between each servo movement
//    - Servos move one joint at a time (coxa, then femur, then tibia)
//      to avoid current spikes from multiple servos moving together
//    - Walking order: Leg 0 (FL) → Leg 1 (FR) → Leg 3 (BR) → Leg 2 (BL)
//      This is a safe stable order — 3 legs always grounded
// ============================================================

#include <Servo.h>
#include <IRremote.hpp>

#define IR_RECEIVE_PIN 2

// ===== IR CODES =====
#define FORWARD_CODE    0xBC43FF00
#define BACKWARD_CODE   0xBB44FF00
#define TURN_LEFT_CODE  0xB946FF00
#define TURN_RIGHT_CODE 0xEA15FF00
#define STOP_CODE       0xBF40FF00
#define MODE_WALK_CODE  0xFF30CF
#define MODE_REST_CODE  0xFF10EF

// ===== IR DEBOUNCE =====
#define IR_DEBOUNCE_MS 150
unsigned long lastIRTime = 0;

// ===== SERVOS =====
Servo coxa[4];
Servo femur[4];
Servo tibia[4];

// ===== BASE POSITIONS =====
//
//  Physical layout (top-down view):
//
//          FRONT
//    [Leg 0]   [Leg 1]
//    Left       Right
//
//    [Leg 2]   [Leg 3]
//    Left       Right
//          BACK
//
int baseCoxa[4] = {90, 90, 90, 90};
int baseFemur   = 110;
int baseTibia   = 75;

// Coxa swing direction per leg:
//   Left  side legs (0, 2): forward = -30
//   Right side legs (1, 3): forward = +30
int coxaDir[4] = {-1, +1, -1, +1};

// Walking order — stable 3-legs-grounded sequence
// FL(0) → FR(1) → BR(3) → BL(2)
int walkOrder[4] = {0, 1, 3, 2};

// ===== TIMING =====
// Increase these if servos are still struggling or power is too low
#define SERVO_SETTLE_MS  80   // pause between individual servo moves
#define PHASE_DELAY_MS   180  // pause between lift / swing / plant phases

// ===== STATE MACHINE =====
enum RobotState { REST, WALK_FORWARD, WALK_BACKWARD, TURN_LEFT, TURN_RIGHT };
RobotState currentState  = REST;
RobotState previousState = WALK_FORWARD; // forces restPose() on first loop

// ===== SETUP =====
void setup() {
  Serial.begin(9600);
  IrReceiver.begin(IR_RECEIVE_PIN, ENABLE_LED_FEEDBACK);

  coxa[0].attach(3);   femur[0].attach(4);   tibia[0].attach(5);
  coxa[1].attach(6);   femur[1].attach(7);   tibia[1].attach(8);
  coxa[2].attach(9);   femur[2].attach(10);  tibia[2].attach(11);
  coxa[3].attach(12);  femur[3].attach(A0);  tibia[3].attach(A1);

  restPose();
}

// ===== LOOP =====
void loop() {

  if (IrReceiver.decode()) {
    unsigned long now = millis();

    if (now - lastIRTime > IR_DEBOUNCE_MS) {
      uint32_t cmd = IrReceiver.decodedIRData.decodedRawData;
      Serial.print("IR: 0x");
      Serial.println(cmd, HEX);

      RobotState newState = currentState;

      if      (cmd == FORWARD_CODE)    newState = WALK_FORWARD;
      else if (cmd == BACKWARD_CODE)   newState = WALK_BACKWARD;
      else if (cmd == TURN_LEFT_CODE)  newState = TURN_LEFT;
      else if (cmd == TURN_RIGHT_CODE) newState = TURN_RIGHT;
      else if (cmd == STOP_CODE)       newState = REST;
      else if (cmd == MODE_WALK_CODE)  newState = WALK_FORWARD;
      else if (cmd == MODE_REST_CODE)  newState = REST;

      if (newState != currentState) {
        previousState = currentState;
        currentState  = newState;
      }

      lastIRTime = now;
    }

    IrReceiver.resume();
  }

  switch (currentState) {
    case WALK_FORWARD:  walkForward();  break;
    case WALK_BACKWARD: walkBackward(); break;
    case TURN_LEFT:     turnLeft();     break;
    case TURN_RIGHT:    turnRight();    break;
    case REST:
      if (previousState != REST) {
        restPose();
        previousState = REST;
      }
      break;
  }
}

// ============================================================
//  LOW-LEVEL HELPERS
//  Each servo moves individually with a settle delay after,
//  so never more than 1 servo draws current at a time.
// ============================================================

void moveCoxa(int leg, int angle) {
  coxa[leg].write(angle);
  delay(SERVO_SETTLE_MS);
}

void moveFemur(int leg, int angle) {
  femur[leg].write(angle);
  delay(SERVO_SETTLE_MS);
}

void moveTibia(int leg, int angle) {
  tibia[leg].write(angle);
  delay(SERVO_SETTLE_MS);
}

// ===== REST (CURLED UP) =====
// Moves one servo at a time across all legs
void restPose() {
  for (int i = 0; i < 4; i++) {
    moveCoxa(i,  90);
    moveFemur(i, 120);
    moveTibia(i, 60);
  }
}

// ============================================================
//  SINGLE LEG STEP
//  Moves exactly one leg through a full step cycle:
//    1. Lift   — femur raises, tibia tucks   (2 servos, sequential)
//    2. Swing  — coxa rotates to target       (1 servo)
//    3. Plant  — femur lowers, tibia extends  (2 servos, sequential)
//  All other legs remain completely still.
// ============================================================
void stepLeg(int leg, int coxaTarget) {
  // --- Phase 1: LIFT ---
  moveFemur(leg, baseFemur + 20);   // raise arm up
  delay(PHASE_DELAY_MS);
  moveTibia(leg, baseTibia + 20);   // tuck elbow up
  delay(PHASE_DELAY_MS);

  // --- Phase 2: SWING ---
  moveCoxa(leg, coxaTarget);        // rotate shoulder to target
  delay(PHASE_DELAY_MS);

  // --- Phase 3: PLANT ---
  moveFemur(leg, baseFemur);        // lower arm down
  delay(PHASE_DELAY_MS);
  moveTibia(leg, baseTibia);        // extend elbow to ground
  delay(PHASE_DELAY_MS);
}

// ============================================================
//  WALK FORWARD
//  Order: FL(0) → FR(1) → BR(3) → BL(2)
//  Each leg steps forward (coxa swings in its forward direction)
//  while the other 3 remain planted.
// ============================================================
void walkForward() {
  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    int target = baseCoxa[leg] + (coxaDir[leg] * 30);
    stepLeg(leg, target);
  }

  // Reset all coxas back to center one at a time
  // (body pushes forward as planted legs return)
  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    moveCoxa(leg, baseCoxa[leg]);
  }
}

// ============================================================
//  WALK BACKWARD
//  Same order, coxa swings in opposite direction
// ============================================================
void walkBackward() {
  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    int target = baseCoxa[leg] - (coxaDir[leg] * 30);
    stepLeg(leg, target);
  }

  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    moveCoxa(leg, baseCoxa[leg]);
  }
}

// ============================================================
//  TURN LEFT
//  Left legs (0, 2) swing backward
//  Right legs (1, 3) swing forward
//  Moved one at a time: FL → FR → BR → BL
// ============================================================
void turnLeft() {
  // Left side swings backward, right side swings forward
  // coxaDir is -1 for left, +1 for right
  // So: left  target = base + (+30) = backward for left
  //     right target = base + (+30) = forward  for right
  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    int target = baseCoxa[leg] + 30; // both sides +30 creates a pivot
    stepLeg(leg, target);
  }

  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    moveCoxa(leg, baseCoxa[leg]);
  }
}

// ============================================================
//  TURN RIGHT
//  Mirror of turnLeft
// ============================================================
void turnRight() {
  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    int target = baseCoxa[leg] - 30;
    stepLeg(leg, target);
  }

  for (int i = 0; i < 4; i++) {
    int leg = walkOrder[i];
    moveCoxa(leg, baseCoxa[leg]);
  }
}
