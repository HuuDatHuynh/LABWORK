#include <Servo.h>
#include <IRremote.hpp>

#define IR_RECEIVE_PIN 2

// ===== IR CODES =====
#define FORWARD_CODE   0xBC43FF00
#define BACKWARD_CODE  0xBB44FF00
#define TURN_LEFT_CODE 0xB946FF00
#define TURN_RIGHT_CODE 0xEA15FF00
#define STOP_CODE      0xBF40FF00

#define MODE_WALK_CODE 0xFF30CF
#define MODE_REST_CODE 0xFF10EF   // curled up

// ===== SERVOS =====
Servo coxa[4];
Servo femur[4];
Servo tibia[4];

// ===== BASE POSITIONS =====
int baseCoxa[4]  = {90, 90, 90, 90};
int baseFemur    = 110;
int baseTibia    = 75;

// ===== MODES =====
enum RobotState { REST, WALK, TURN_LEFT, TURN_RIGHT };
RobotState currentState = REST;

// ===== SETUP =====
void setup() {
  Serial.begin(9600);

  IrReceiver.begin(IR_RECEIVE_PIN, ENABLE_LED_FEEDBACK);

  // Attach servos
  coxa[0].attach(3);  femur[0].attach(4);  tibia[0].attach(5);
  coxa[1].attach(6);  femur[1].attach(7);  tibia[1].attach(8);
  coxa[2].attach(9);  femur[2].attach(10); tibia[2].attach(11);
  coxa[3].attach(12); femur[3].attach(13); tibia[3].attach(A0);

  restPose();
}

// ===== LOOP =====
void loop() {

  if (IrReceiver.decode()) {
    uint32_t cmd = IrReceiver.decodedIRData.decodedRawData;
    Serial.println(cmd, HEX);

    if (cmd == MODE_WALK_CODE) currentState = WALK;
    if (cmd == MODE_REST_CODE) currentState = REST;

    if (cmd == FORWARD_CODE) currentState = WALK;
    if (cmd == TURN_LEFT_CODE) currentState = TURN_LEFT;
    if (cmd == TURN_RIGHT_CODE) currentState = TURN_RIGHT;

    if (cmd == STOP_CODE) currentState = REST;

    IrReceiver.resume();
  }

  switch (currentState) {
    case WALK: walkForward(); break;
    case TURN_LEFT: turnLeft(); break;
    case TURN_RIGHT: turnRight(); break;
    case REST: restPose(); break;
  }
}

// ===== SERVO CONTROL =====
void moveServo(int leg, int c, int f, int t) {
  coxa[leg].write(c);
  femur[leg].write(f);
  tibia[leg].write(t);
}

// ===== REST (CURLED UP) =====
void restPose() {
  for (int i = 0; i < 4; i++) {
    moveServo(i, 90, 120, 60); // curled up
  }
}

// ===== WALK (HEAVY + SLOW + 30 DEG) =====
void walkForward() {

  int d = 250;

  for (int i = 0; i < 4; i++) {

    // lift (2 servos)
    moveServo(i, baseCoxa[i], baseFemur + 10, baseTibia + 10);
    delay(d);

    // swing (30°)
    moveServo(i, baseCoxa[i] - 30, baseFemur + 10, baseTibia + 10);
    delay(d);

    // set down
    moveServo(i, baseCoxa[i] - 30, baseFemur, baseTibia);
    delay(d);
  }
}

// ===== TURN LEFT =====
void turnLeft() {

  int d = 250;

  // Left legs forward
  moveServo(0, baseCoxa[0] - 30, baseFemur + 10, baseTibia + 10);
  moveServo(2, baseCoxa[2] - 30, baseFemur + 10, baseTibia + 10);
  delay(d);

  moveServo(0, baseCoxa[0] - 30, baseFemur, baseTibia);
  moveServo(2, baseCoxa[2] - 30, baseFemur, baseTibia);
  delay(d);

  // Right legs backward
  moveServo(1, baseCoxa[1] + 30, baseFemur + 10, baseTibia + 10);
  moveServo(3, baseCoxa[3] + 30, baseFemur + 10, baseTibia + 10);
  delay(d);

  moveServo(1, baseCoxa[1] + 30, baseFemur, baseTibia);
  moveServo(3, baseCoxa[3] + 30, baseFemur, baseTibia);
  delay(d);
}

// ===== TURN RIGHT =====
void turnRight() {

  int d = 250;

  // Right legs forward
  moveServo(1, baseCoxa[1] + 30, baseFemur + 10, baseTibia + 10);
  moveServo(3, baseCoxa[3] + 30, baseFemur + 10, baseTibia + 10);
  delay(d);

  moveServo(1, baseCoxa[1] + 30, baseFemur, baseTibia);
  moveServo(3, baseCoxa[3] + 30, baseFemur, baseTibia);
  delay(d);

  // Left legs backward
  moveServo(0, baseCoxa[0] - 30, baseFemur + 10, baseTibia + 10);
  moveServo(2, baseCoxa[2] - 30, baseFemur + 10, baseTibia + 10);
  delay(d);

  moveServo(0, baseCoxa[0] - 30, baseFemur, baseTibia);
  moveServo(2, baseCoxa[2] - 30, baseFemur, baseTibia);
  delay(d);
}
